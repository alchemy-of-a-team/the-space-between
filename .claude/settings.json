{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Agent"
    ],
    "additionalDirectories": [
      "/Users/rich",
      "/Users/rich/.claude/context"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git push*)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-push-validate.sh",
            "timeout": 300,
            "statusMessage": "Pre-push: type check + build + team review gate..."
          }
        ]
      }
    ]
  }
}
